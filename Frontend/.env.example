# Frontend runtime configuration
# Copy this file to .env.local and update values as needed.

# Backend API base URL
# Local backend default: http://localhost:5001/
VITE_APP_URL=http://localhost:5001/

# Demo auth mode: true means sign-up/sign-in works without backend/DB.
# Keep true for presentations and minor-project demos.
VITE_DEMO_AUTH=true

# Backward-compatible alias used in older code paths
VITE_BASE_URL=http://localhost:5001/

# Gemini API key for AI content generation
# Prefer this variable name
VITE_GEMINI_API_KEY=

# Backward-compatible typo alias (kept for old references)
VITE_GEMENI_API_KEY=

# Optional: Strapi token for legacy endpoints
VITE_STRAPI_API_KEY=

# Optional: Clerk auth key if using Clerk auth flow
VITE_CLERK_PUBLISHABLE_KEY=
